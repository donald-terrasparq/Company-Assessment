# ─── Database ───────────────────────────────────────────────
# Local/Codespaces: a Neon DEV branch. Production: auto-wired by Render from company-assessment-db.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── Auth ───────────────────────────────────────────────────
AUTH_SECRET=""                 # openssl rand -base64 32
AUTH_URL="http://localhost:3000"   # production: https://app.ctsmobility.com (your Render custom domain)
SEED_ADMIN_USER="admin"
SEED_ADMIN_PASSWORD=""         # change immediately after first login

# ─── Anthropic (SERVER ONLY — never NEXT_PUBLIC_) ───────────
ANTHROPIC_API_KEY=""

# ─── Search providers ───────────────────────────────────────
BRAVE_API_KEY=""               # free tier ~2k queries/mo
GOOGLE_CSE_KEY=""              # optional; 100 queries/day free
GOOGLE_CSE_ID=""
# SEC EDGAR needs no key. It does require a descriptive User-Agent:
SEC_USER_AGENT="CTS Mobility Company Assessment (ops@ctsmobility.com)"

# ─── Storage (raw uploaded spreadsheets) ────────────────────
# Render Persistent Disk needs no key. For S3-compatible storage instead:
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_REGION=""

# ─── Background worker (Render) ─────────────────────────────
WORKER_CONCURRENCY="4"         # companies processed in parallel per loop tick
WORKER_POLL_MS="5000"          # idle sleep between empty queue checks
# CRON_SECRET is only needed for the OPTIONAL Vercel driver (deploy/vercel-alternate/).
# CRON_SECRET=""

# ─── Phase 2 ────────────────────────────────────────────────
APOLLO_API_KEY=""
